# ─── Database ────────────────────────────────────────────────
# For production (Neon): postgresql://user:pass@host/clashfree?sslmode=require
# For local dev: postgresql://localhost:5432/clashfree_dev
DATABASE_URL="postgresql://localhost:5432/clashfree_dev"

# ─── NextAuth ────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# In Vercel, set NEXTAUTH_URL to your deployment URL automatically
