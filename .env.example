# ─── Database ────────────────────────────────────────────────
# For production (Neon): postgresql://user:pass@host/clashfree?sslmode=require
# For local dev: postgresql://localhost:5432/clashfree_dev
DATABASE_URL="postgresql://localhost:5432/clashfree_dev"

# ─── NextAuth ────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# In Vercel, set NEXTAUTH_URL to your deployment URL automatically

# ─── Email (Resend) ──────────────────────────────────────────────
# Get free API key at https://resend.com (3,000 emails/month free)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─── WhatsApp (Meta Cloud API) ───────────────────────────────────
# Set up at https://developers.facebook.com/apps → WhatsApp → API Setup
WA_PHONE_NUMBER_ID=1234567890
WA_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxx
# Set to "true" once templates are approved in Meta Business Manager
WA_USE_TEMPLATES=false
